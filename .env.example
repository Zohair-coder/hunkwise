NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgres://hunkwise:hunkwise@localhost:5432/hunkwise
# Local-only PostgreSQL setting. Omit in production to default to verify-full.
DATABASE_SSL_MODE=disable
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key
# Optional; required only when triggering OpenAI-backed review runs.
OPENAI_API_KEY=
# Optional; defaults to gpt-4.1-mini.
OPENAI_MODEL=gpt-4.1-mini
# Optional but required for /api/webhooks/gitlab/:instanceId.
GITLAB_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
# Optional in development; defaults to apps/web/dist in production.
WEB_DIST_DIR=
