{
  "name": "@hunkwise/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/main.ts --format esm --sourcemap --clean",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.1",
    "@fastify/static": "^9.1.3",
    "@hunkwise/contracts": "0.1.0",
    "@hunkwise/db": "0.1.0",
    "fastify": "^5.3.3",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^3.1.4",
    "tsx": "^4.19.4",
    "tsup": "^8.5.0",
    "vitest": "^3.1.4"
  }
}
