{
  "name": "@hunkwise/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "build": "tsup src/index.ts src/migrate.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@hunkwise/contracts": "0.1.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.2",
    "@vitest/coverage-v8": "^3.1.4",
    "tsx": "^4.19.4",
    "tsup": "^8.5.0",
    "vitest": "^3.1.4"
  }
}

