{
  "name": "@hunkwise/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/migrate.ts src/ssl.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@hunkwise/contracts": "0.1.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@types/pg": "^8.15.2",
    "@vitest/coverage-v8": "^3.1.4",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "vitest": "^3.1.4"
  }
}
